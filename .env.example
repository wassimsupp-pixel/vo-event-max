# VO Event Max — Environment Variables
# Copy to .env.local (web) and .env (api) and fill in real values
# NEVER commit .env files to git

# ─── Supabase (Paris region — eu-west-3) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # API only, never expose to browser
SUPABASE_STORAGE_BUCKET=event-files

# ─── FastAPI Backend (Railway EU) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-api.railway.app
SECRET_KEY=generate-a-secure-random-key-here
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ─── App ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
