# VO Event Max — API Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ----------------------------------------------------------
# Supabase
# ----------------------------------------------------------
# Project URL from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service Role key (bypasses RLS — keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Name of the private Storage bucket for uploaded files
SUPABASE_STORAGE_BUCKET=event-files

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
# Used to sign internal tokens if needed; generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Port used by uvicorn (Railway injects $PORT automatically)
PORT=8000
