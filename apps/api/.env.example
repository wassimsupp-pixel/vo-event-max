# VO Event Max — API Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ----------------------------------------------------------
# Supabase
# ----------------------------------------------------------
# Project URL from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Service Role key (bypasses RLS — keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Name of the private Storage bucket for uploaded files
SUPABASE_STORAGE_BUCKET=event-files

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
# Used to sign internal tokens if needed; generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Port used by uvicorn (Railway injects $PORT automatically)
PORT=8000

# ----------------------------------------------------------
# Mail connection (OAuth) — Email Agent inbox sync
# ----------------------------------------------------------
# See docs/mail-connection-setup.md for how to register the OAuth apps.
# Leave a provider's id/secret empty to disable it (the UI shows "Not configured").

# Google / Gmail (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft / Outlook (Entra ID → App registrations)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# "common" = personal + work/school accounts; or set a specific tenant id
MICROSOFT_TENANT_ID=common

# Must exactly match the redirect URI registered in BOTH OAuth apps, pointing
# at this API's callback route:
MAIL_OAUTH_REDIRECT_URI=http://localhost:8000/api/mail/oauth/callback

# Frontend base URL the callback bounces the user back to after consent
WEB_APP_URL=http://localhost:3000

# Max number of recent inbox messages pulled per manual sync
MAIL_SYNC_MAX_MESSAGES=20

# ----------------------------------------------------------
# AI (optional) — Email Agent parsing
# ----------------------------------------------------------
# Google Gemini API key. If unset, the Email Agent uses a deterministic
# rule-based fallback parser.
GEMINI_API_KEY=
